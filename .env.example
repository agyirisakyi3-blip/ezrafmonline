# ─── Database ────────────────────────────────────────
# PostgreSQL (required — SQLite does not work on Vercel)
# Get a free serverless Postgres at https://neon.tech
# Then paste the connection string here (it looks like: postgresql://user:pass@ep-xxx-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require)
DATABASE_URL="postgresql://user:password@ep-xxx-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=verify-full"

# ─── NextAuth (required) ────────────────────────────
# Generate a secret with: openssl rand -hex 32
AUTH_SECRET="change-me-to-a-random-64-char-hex-string"

# ─── Site URL (required) ────────────────────────────
# Must match your production domain exactly.
# Used for canonical URLs, OG tags, JSON-LD, metadata base.
AUTH_URL="https://yourdomain.com"

# ─── Revalidation API (recommended) ─────────────────
# Secret for on-demand cache purging via /api/revalidate
# Generate with: openssl rand -hex 32
REVALIDATION_SECRET="change-me-to-a-random-64-char-hex-string"

# ─── Rate Limiting (recommended for high traffic) ──
# Upstash Redis REST API credentials. Without these, rate limiting
# falls back to in-memory (per-instance, not shared across serverless functions).
# Get a free Redis instance at: https://upstash.com
UPSTASH_REDIS_REST_URL="https://your-region.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-token"

# ─── Weather (optional) ────────────────────────────
# Get a free API key at: https://openweathermap.org/api
WEATHER_API_KEY=""
WEATHER_CITY="Accra"

# ─── Google Analytics (optional) ───────────────────
# Get your GA4 measurement ID from https://analytics.google.com
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# ─── Google Search Console (optional) ──────────────
# Verification string from https://search.google.com/search-console
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION="your-verification-string"

# ─── Vercel Blob (required for image uploads on Vercel) ──
# Get your token from: https://vercel.com/docs/storage/vercel-blob
# Then add it to your Vercel project's environment variables.
# Local development falls back to public/uploads/ automatically.
BLOB_READ_WRITE_TOKEN=""
